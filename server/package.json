{
  "name": "web-final-proj-server",
  "version": "1.0.0",
  "description": "",
  "main": "app.js",
  "scripts": {
    "build": "tsc",
    "start": "tsc && node --env-file=.env ./dist/src/app.js",
    "dev": "nodemon --exec ts-node -r dotenv/config src/app.ts",
    "prod": "cp .envprod .env && tsc -p tsconfig_prod.json && pm2 restart ecosystem.config.ts --env production",
    "prod1": "cp .envprod .env && tsc -p tsconfig_prod.json && node dist/src/app.js",
    "debug": "node --env-file=.env --inspect dist/app.js",
    "coverage": "tsc && jest --detectOpenHandles --coverage --runInBand --forceExit",
    "test": "tsc && jest --detectOpenHandles --runInBand --forceExit",
    "verify-indexes": "tsc && node --env-file=.env dist/scripts/verifyIndexes.js",
    "generate-embeddings": "tsc && node --env-file=.env dist/scripts/generateEmbeddings.js",
    "usersTest": "tsc && jest --detectOpenHandles --forceExit --runInBand ./src/tests/users.test.ts",
    "commentsTest": "tsc && jest --detectOpenHandles --forceExit --runInBand ./src/tests/comments.test.ts",
    "postsTest": "tsc && jest --detectOpenHandles --forceExit --runInBand ./src/tests/posts.test.ts",
    "authTest": "tsc && jest --detectOpenHandles --forceExit --runInBand ./src/tests/auth.test.ts"
  },
  "author": "Amit Sahar And Sivan Alchasov",
  "license": "ISC",
  "dependencies": {
    "@types/express": "^4.17.21",
    "bcrypt": "^5.1.1",
    "bunyan": "^1.8.15",
    "bunyan-format": "^0.2.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "envalid": "^8.1.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "google-auth-library": "^10.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.2",
    "multer": "^2.0.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pm2": "^6.0.14",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/supertest": "^2.0.16",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.6",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.1",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}